# Synapse AI — Environment Configuration
# Copy this file to .env and fill in your API keys.

# ── Application ───────────────────────────────────────────
APP_NAME="Synapse AI"
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://synapse:synapse@localhost:5432/synapse"

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS='["http://localhost:3000"]'

# ── Provider API Keys ─────────────────────────────────────
# At least one of these is required for production debates.
# Mock providers work without any API key for testing.

# Gemini (Agent A — Balanced Analyst, Consensus Agent)
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Groq (Agent B — Critical Reviewer)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

# OpenRouter (Agent C — Devil's Advocate)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-r1"

# OpenAI (Legacy / direct model access)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

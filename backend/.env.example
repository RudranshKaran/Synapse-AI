# Synapse AI — Environment Configuration

# Application
APP_NAME=Synapse AI
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://synapse:synapse@localhost:5432/synapse

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# LLM Providers
# DEFAULT_PROVIDER controls which provider is used when creating debates.
# Valid values: "mock" (default), "openai"
DEFAULT_PROVIDER=mock

# OpenAI Configuration
# Required only when using the "openai" provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
